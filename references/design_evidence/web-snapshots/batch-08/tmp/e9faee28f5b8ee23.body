document.addEventListener("DOMContentLoaded", function () {
   const githubIcon = document.querySelector("#social-in-menu a > i.fa-github-alt");

   if (!githubIcon) return;

   // prevent duplicate injection
   if (document.querySelector("#social-in-menu .download-icont")) return;

   const downloadIcon = document.createElement("i");
   downloadIcon.className = "fa fa-download download-icont";
   downloadIcon.setAttribute("aria-hidden", "true");

   // insert BEFORE the GitHub icon
   githubIcon.parentNode.insertBefore(downloadIcon, githubIcon);
});
</script>
